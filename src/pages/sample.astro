---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import TradeMap from '../components/TradeMap.astro';
import CtaBand from '../components/CtaBand.astro';
import Footer from '../components/Footer.astro';
import { genComps } from '../lib/tradeComps.js';

// shared comp sets for the trade-area maps — drive both the lettered map dots
// and the distance charts so they (and the "nearest comp" stat) stay in sync.
const compsX = genComps(12, 7, 0.03);  // Concept X · sushi · 7-mi radius
const compsY = genComps(10, 5, 1.4);   // Concept Y · bagels · 5-mi radius
---
<Base
  title="See a real CLA — two concepts, one method (anonymized)"
  description="Two real, anonymized CLAs side by side — a pre-opening bagel concept and an operating sushi concept. First four selling points public; email unlocks the rest."
>
  <Nav />

  <section class="sample">
    <div class="container">
      <!-- HERO -->
      <div class="head">
        <div class="meta-row">
          <span>cl-analysis.com / sample</span>
          <span class="dot">·</span>
          <span>Anonymized</span>
          <span class="dot">·</span>
          <span>Two concepts</span>
          <span class="dot">·</span>
          <span>Vol. 01 · 2026</span>
        </div>
        <h1>One method. <span class="italic">Two concepts.</span></h1>
        <p class="lead">The same CLA, run on two very different restaurants. <strong>Concept X</strong> is an <em>operating</em> sushi concept; <strong>Concept Y</strong> is a <em>pre-opening</em> bagel concept. Every figure is pulled from a real delivered report — only the identifying details are masked. Compare them side by side, selling point by selling point.</p>
        <div class="brand-legend">
          <div class="bl-item"><span class="bl-tag bl-x">Concept X</span> Sushi · operating</div>
          <div class="bl-item"><span class="bl-tag bl-y">Concept Y</span> Bagels · pre-opening</div>
        </div>
      </div>

      <!-- EXECUTIVE READ — taste of the verdict; full overview + $-deltas gated -->
      <section class="exec-taste">
        <div class="et-eyebrow">The executive read · the verdict behind the data</div>
        <div class="et-grid">
          <article class="et-card">
            <div class="et-head"><span class="pane-brand">Concept X</span><span class="pane-kind">Sushi · operating</span></div>
            <div class="et-verdict">Operate at the <strong>mid-market tier</strong> — positioned between the value and premium ends of the field.</div>
            <div class="et-label adv">Advantages</div>
            <ul class="et-list adv">
              <li>Core rolls land in the $7–9 mid-market sweet spot — between the value tier and the premium chains.</li>
              <li>Only full-format sushi + hibachi + ramen concept in the trade area — cross-category convenience no single-category comp matches.</li>
              <li>Premium protein cuts justify a ~20% premium over comps trading on lower-grade cuts.</li>
            </ul>
            <div class="et-label risk">Risks</div>
            <ul class="et-list risk">
              <li>Guest rating #9 of 12 — below the top quartile; review volume is the gap to close.</li>
              <li>Dense field — 14 direct comps within 5 mi; absorbed by high trade-area income, but competitive.</li>
            </ul>
          </article>
          <article class="et-card">
            <div class="et-head"><span class="pane-brand">Concept Y</span><span class="pane-kind">Bagels · pre-opening</span></div>
            <div class="et-verdict">Hold a <strong>premium-with-headroom tier</strong> — priced at/under the local ceiling on day one, not maxed out.</div>
            <div class="et-label adv">Advantages</div>
            <ul class="et-list adv">
              <li>Differentiator stack — 7 of 25 specialty spreads (plus 5 specialty bagels) face no direct peer in the trade area.</li>
              <li>Breakfast &amp; lunch sit below market — real headroom to price up post-open.</li>
              <li>Core items priced at/under the local ceiling — a disciplined premium with room to lift.</li>
            </ul>
            <div class="et-label risk">Risks</div>
            <ul class="et-list risk">
              <li>Trade-area income runs ~13.5% below the U.S. average — caps premium-tub and specialty-coffee pricing power.</li>
              <li>Latte priced +36% above market — watch-flag the beverage program at open.</li>
            </ul>
          </article>
        </div>
        <div class="et-foot">Headline verdict only — the full executive overview, dollar-delta recommendations and tier justification are in the report. <a href="#gate">Unlock the rest ↓</a></div>
      </section>

      <!-- COMPARE 01 — MENU & PRICING -->
      <section class="compare">
        <div class="c-head">
          <div class="c-eyebrow">Selling point 01 · Menu &amp; Pricing</div>
          <h2>Item-level pricing, against the real market</h2>
          <p class="c-sub">Every item priced against the lowest- and highest-priced direct comp in the trade area — bagels or sushi rolls, the read is the same.</p>
        </div>
        <div class="compare-grid stack">
          <article class="pane">
            <div class="pane-head"><span class="pane-brand">Concept X</span><span class="pane-kind">Sushi · operating</span></div>
            <figure><img src="/shots/module-01-pricing-y.png" width="1960" height="710" loading="lazy" alt="Concept X sushi roll item pricing table — each roll with its lowest and highest direct comp and the market average" /></figure>
          </article>
          <article class="pane">
            <div class="pane-head"><span class="pane-brand">Concept Y</span><span class="pane-kind">Bagels · pre-opening</span></div>
            <figure><img src="/shots/module-01-pricing.png" width="2280" height="920" loading="lazy" alt="Concept Y bagel item pricing table — each item with its lowest and highest direct comp and the market band" /></figure>
          </article>
        </div>
        <div class="insight-flag">
          <strong>Insight:</strong> Concept-agnostic. Whether the line item is a <em>California roll</em> or a <em>plain bagel</em>, the report fixes each price against named (here masked) comps so you set the menu with intent, not a guess.
        </div>
      </section>

      <!-- COMPARE 02 — TRADE AREA -->
      <section class="compare">
        <div class="c-head">
          <div class="c-eyebrow">Selling point 02 · Market &amp; Trade Area</div>
          <h2>Who you're really up against, mapped</h2>
          <p class="c-sub">Direct comps plotted inside the trade-area radius, with the saturation read that comes with them.</p>
        </div>
        <div class="compare-grid">
          <article class="pane">
            <div class="pane-head"><span class="pane-brand">Concept X</span><span class="pane-kind">Sushi · 7-mi radius</span></div>
            <div class="map-pane-body">
              <div class="mini-map-wrap"><TradeMap id="map-x" center={[32.9618, -96.8916]} zoom={11} radiusMi={7} compCount={12} nearestMi={0.03} /></div>
              <div class="mini-legend">
                <span class="ml-row"><span class="leg-dot you-dot"></span> Subject</span>
                <span class="ml-row"><span class="leg-dot comp-dot"></span> 12 direct comps</span>
                <span class="ml-row"><span class="leg-dash"></span> 7-mi boundary</span>
              </div>
              <div class="mini-stats">
                <div class="ms"><span class="ms-v">12</span><span class="ms-l">Direct comps · 7 mi</span></div>
                <div class="ms"><span class="ms-v">0.03<small>mi</small></span><span class="ms-l">Nearest comp</span></div>
                <div class="ms"><span class="ms-v">4.2<small>★</small></span><span class="ms-l">Subject · operating</span></div>
                <div class="ms"><span class="ms-v">#9<small>/12</small></span><span class="ms-l">Guest-rating rank</span></div>
              </div>
              <div class="comp-dist">
                <div class="cd-head">Comp distance from subject <span class="cd-unit">· mi · nearest → farthest</span></div>
                <ul class="cd-rows">
                  {compsX.map((c) => (
                    <li class="cd-row">
                      <span class="cd-letter">Comp {c.letter}</span>
                      <span class="cd-track"><span class="cd-fill" style={`width:${Math.max(3, (c.distMi / 7) * 100)}%`}></span></span>
                      <span class="cd-mi">{c.distMi.toFixed(2)}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
          <article class="pane">
            <div class="pane-head"><span class="pane-brand">Concept Y</span><span class="pane-kind">Bagels · 5-mi radius</span></div>
            <div class="map-pane-body">
              <div class="mini-map-wrap"><TradeMap id="map-y" center={[26.0628, -80.2528]} zoom={11} radiusMi={5} compCount={10} nearestMi={1.4} /></div>
              <div class="mini-legend">
                <span class="ml-row"><span class="leg-dot you-dot"></span> Subject</span>
                <span class="ml-row"><span class="leg-dot comp-dot"></span> 10 direct comps</span>
                <span class="ml-row"><span class="leg-dash"></span> 5-mi boundary</span>
              </div>
              <div class="mini-stats">
                <div class="ms"><span class="ms-v">B+</span><span class="ms-l">Saturation grade</span></div>
                <div class="ms"><span class="ms-v">10</span><span class="ms-l">Direct comps · 5 mi</span></div>
                <div class="ms"><span class="ms-v">1.4<small>mi</small></span><span class="ms-l">Nearest comp</span></div>
                <div class="ms"><span class="ms-v">+2</span><span class="ms-l">New entrants · 8 mi</span></div>
              </div>
              <div class="comp-dist">
                <div class="cd-head">Comp distance from subject <span class="cd-unit">· mi · nearest → farthest</span></div>
                <ul class="cd-rows">
                  {compsY.map((c) => (
                    <li class="cd-row">
                      <span class="cd-letter">Comp {c.letter}</span>
                      <span class="cd-track"><span class="cd-fill" style={`width:${Math.max(3, (c.distMi / 5) * 100)}%`}></span></span>
                      <span class="cd-mi">{c.distMi.toFixed(2)}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        </div>
        <div class="insight-flag">
          <strong>Insight:</strong> Concept X's nearest direct comp sits <em>0.03 mi</em> away — effectively next door — inside a 12-deep field. Concept Y's trade area is lighter at <em>B+</em> saturation. Same map, two completely different competitive realities.
        </div>
      </section>

      <!-- COMPARE 03 — LOCAL WAGES -->
      <section class="compare">
        <div class="c-head">
          <div class="c-eyebrow">Selling point 03 · Local Wages &amp; Cost Context</div>
          <h2>Pay benchmarks for the actual trade area</h2>
          <p class="c-sub">Position-by-position pay — legal floor, market average, full range and annual estimate — drawn from local data, not state averages.</p>
        </div>
        <div class="compare-grid">
          <article class="pane">
            <div class="pane-head"><span class="pane-brand">Concept X</span><span class="pane-kind">Sushi · $7.25 floor market</span></div>
            <figure><img src="/shots/module-03-wages-y.png" width="2160" height="828" loading="lazy" alt="Concept X local wage benchmarks by position — legal floor, average hourly, range and annual estimate" /></figure>
          </article>
          <article class="pane">
            <div class="pane-head"><span class="pane-brand">Concept Y</span><span class="pane-kind">Bagels · $15 floor market</span></div>
            <figure><img src="/shots/module-03-wages.png" width="1142" height="492" loading="lazy" alt="Concept Y local wage benchmarks by position — legal floor, average hourly, range and annual estimate" /></figure>
          </article>
        </div>
        <div class="insight-flag">
          <strong>Insight:</strong> The legal floor alone swings from <em>$7.25</em> in Concept X's market to <em>$15.00</em> in Concept Y's — a labor-model difference you cannot guess from a national table. Each role carries its real local band.
        </div>
      </section>

      <!-- COMPARE 04 — GUEST SENTIMENT -->
      <section class="compare">
        <div class="c-head">
          <div class="c-eyebrow">Selling point 04 · Guest Sentiment</div>
          <h2>Where you rank on the leaderboard</h2>
          <p class="c-sub">Every direct comp's guest rating, ranked. The report adapts: a pre-opening concept gets the field to beat; an operating one gets its own slot called out.</p>
        </div>
        <div class="compare-grid">
          <article class="pane">
            <div class="pane-head"><span class="pane-brand">Concept X</span><span class="pane-kind">Sushi · operating · ranked in field</span></div>
            <figure><img src="/shots/module-04-sentiment.png" width="1960" height="1042" loading="lazy" alt="Concept X guest sentiment — subject called out in orange, ranked against every direct competitor's rating and review count" /></figure>
            <div class="sent-warning"><span class="sw-tag">⚠ Tier 1</span> Guest sentiment below the top 25% of the trade-area field — review <em>volume</em> is the gap to close.</div>
          </article>
          <article class="pane">
            <div class="pane-head"><span class="pane-brand">Concept Y</span><span class="pane-kind">Bagels · pre-opening · field only</span></div>
            <figure><img src="/shots/module-04-sentiment-x.png" width="1960" height="880" loading="lazy" alt="Concept Y guest sentiment — every direct competitor's star rating ranked high to low; no subject bar because the concept is pre-opening" /></figure>
          </article>
        </div>
        <div class="insight-flag">
          <strong>Insight:</strong> Operating Concept X is placed in the field at <em>4.2★ (#9 of 12)</em> — below the top quartile, with review <em>volume</em> the gap to close. Pre-opening Concept Y gets a clean read on the <em>bar to clear</em>.
        </div>
      </section>

      <!-- COMPARE 05 — CATEGORY DEPTH -->
      <section class="compare">
        <div class="c-head">
          <div class="c-eyebrow">Selling point 05 · Category Depth</div>
          <h2>Every category, priced against the market band</h2>
          <p class="c-sub">Each item set against the market <em>High</em> / <em>Average</em> / <em>Low</em> — so you see exactly where the menu sits, category by category, not just on the headline items.</p>
        </div>

        <div class="cat-brand">
          <div class="cat-brand-label"><span class="pane-brand">Concept X</span><span class="pane-kind">Sushi · operating</span></div>
          <div class="compare-grid">
            <article class="pane">
              <div class="pane-head"><span class="pane-cat">Classic Rolls</span></div>
              <figure><img src="/shots/module-05-y-rolls.png" width="1520" height="1020" loading="lazy" alt="Concept X classic roll pricing vs market high, average and low band" /></figure>
            </article>
            <article class="pane">
              <div class="pane-head"><span class="pane-cat">Ramen</span></div>
              <figure><img src="/shots/module-05-y-ramen.png" width="1520" height="1020" loading="lazy" alt="Concept X ramen pricing vs market high, average and low band" /></figure>
            </article>
          </div>
        </div>

        <div class="cat-brand">
          <div class="cat-brand-label"><span class="pane-brand">Concept Y</span><span class="pane-kind">Bagels · pre-opening</span></div>
          <div class="compare-grid">
            <article class="pane">
              <div class="pane-head"><span class="pane-cat">Breakfast Sandwiches</span></div>
              <figure><img src="/shots/module-05-x-breakfast.png" width="1520" height="700" loading="lazy" alt="Concept Y breakfast sandwich pricing vs market high, average and low band; breakfast burrito has no direct comp" /></figure>
              <div class="cat-callout"><span class="cc-tag">★ Differentiator</span> <strong>Breakfast Burrito</strong> has no direct comp in the trade area — a Concept Y market exclusive, so it carries only the subject bar (no market band to price against).</div>
            </article>
            <article class="pane">
              <div class="pane-head"><span class="pane-cat">Coffee</span></div>
              <figure><img src="/shots/module-05-x-coffee.png" width="1520" height="608" loading="lazy" alt="Concept Y coffee pricing vs market high, average and low band" /></figure>
            </article>
          </div>
        </div>

        <div class="insight-flag">
          <strong>Insight:</strong> Concept X's rolls sit at or below the market <em>average</em> across the core menu — room to lift. Concept Y, pre-opening, gets the full band to price into on day one. Same read, applied category by category.
        </div>
      </section>

      <!-- RECOMMENDATION — tier call + justification (taste; per-SKU moves + $-deltas gated) -->
      <section class="rec-taste">
        <div class="rt-eyebrow">The recommendation · what to price, and why</div>
        <div class="rt-grid">
          <article class="rt-card">
            <div class="rt-head"><span class="pane-brand">Concept X</span><span class="pane-kind">Sushi · operating</span></div>
            <div class="rt-tier">Hold the <strong>mid-market tier</strong></div>
            <p class="rt-why">Captures the $7–9 sweet spot between the value tier and the premium chains, keeps specialty rolls ~11% under the premium leader — the defining value-vs-premium gap — and leans on cross-category breadth (sushi + hibachi + ramen) no single-category comp matches.</p>
          </article>
          <article class="rt-card">
            <div class="rt-head"><span class="pane-brand">Concept Y</span><span class="pane-kind">Bagels · pre-opening</span></div>
            <div class="rt-tier">Hold the <strong>premium-with-headroom tier</strong></div>
            <p class="rt-why">Prices core items at/under the local ceiling on day one — a disciplined premium, not maxed out — defends specialty spreads on no-direct-peer differentiators, and leaves breakfast &amp; lunch headroom to lift post-open.</p>
          </article>
        </div>
        <div class="rt-foot">Per-SKU pricing moves and the exact dollar deltas are in the report. <a href="#gate">Unlock the rest ↓</a></div>
      </section>

      <!-- GATE -->
      <div class="gate" id="gate">
        <article class="module-block teaser">
          <header>
            <span class="mod-num">06</span>
            <div>
              <div class="mod-tag">Locked · ezCater · Third-Party Delivery · Overview</div>
              <h2>Platform markup, catering tiers &amp; the executive read</h2>
            </div>
            <span class="mod-status locked">🔒 Locked</span>
          </header>
          <div class="block-body teaser-body">
            <div class="teaser-grid">
              <figure class="real-shot">
                <img src="/shots/module-06-markup.png"
                  alt="Third-party delivery markup heatmap — average markup each competitor's UberEats, DoorDash and Grubhub prices carry over their direct menu"
                  width="2536" height="1722" loading="lazy" />
              </figure>
              <figure class="real-shot">
                <img src="/shots/module-06-coverage.png"
                  alt="Third-party delivery coverage grid — which platforms each competitor is live on"
                  width="2536" height="1804" loading="lazy" />
              </figure>
            </div>
            <div class="teaser-veil"></div>
          </div>
        </article>

        <div class="gate-card">
          <div class="gate-label">Unlock the rest · both concepts</div>
          <h3>One email. Instant access.</h3>
          <p>You've seen pricing, trade area, wages and sentiment for both concepts. Drop your email and I'll send the full sample — <strong>ezCater catering tiers</strong>, <strong>third-party delivery markup</strong>, the per-category deep dives and the <strong>executive overview</strong> — for the pre-opening bagel concept <em>and</em> the operating sushi concept.</p>
          <form action="/api/subscribe" method="POST" class="gate-form"
            data-async data-source="sample-unlock"
            data-success="Got it — the full sample is on its way to your inbox. I'll follow up personally.">
            <input type="email" name="email" placeholder="you@brand.com" required />
            <button type="submit" class="btn-primary">Unlock Full Sample<span class="arrow">→</span></button>
          </form>
          <div class="gate-fine">One-time. Unsubscribe in one click. No CRM, no list resale.</div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
  <Footer />
</Base>

<style>
  .sample { padding: 4rem 2rem 0; background: var(--canvas); }
  .container { max-width: var(--max); margin: 0 auto; }
  .head { margin-bottom: 3.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--ink); }
  .head .meta-row { margin-bottom: 1.5rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--hairline); }
  h1 {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(2.4rem, 5vw, 3.8rem); line-height: 1.04; letter-spacing: -0.025em;
    color: var(--ink); margin-bottom: 1rem;
    font-variation-settings: "opsz" 96;
  }
  h1 .italic { font-style: italic; color: var(--periwinkle-deep); }
  .lead {
    font-family: var(--serif); font-weight: 300; font-size: 1.08rem; line-height: 1.6;
    color: var(--body); max-width: 48em; font-variation-settings: "opsz" 20;
  }
  .lead strong { font-weight: 600; color: var(--ink); }
  .lead em { font-style: italic; color: var(--cocoa); }
  .brand-legend { display: flex; gap: 2rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .bl-item { font-family: var(--mono); font-size: 0.78rem; color: var(--cocoa); display: flex; align-items: center; gap: 0.5rem; }
  .bl-tag {
    font-weight: 700; letter-spacing: 0.08em; padding: 0.25rem 0.55rem;
    color: var(--canvas); background: var(--periwinkle-deep); font-size: 0.7rem;
  }
  .bl-tag.bl-y { background: var(--cocoa); }

  /* Executive read — per-concept advantages/risks taste (full verdict gated) */
  .exec-taste { margin-bottom: 4rem; }
  .et-eyebrow { font-family: var(--mono); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--periwinkle-deep); margin-bottom: 1rem; }
  .et-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: stretch; }
  .et-card { border: 1px solid var(--tan); background: var(--canvas); padding: 1.4rem 1.5rem; display: flex; flex-direction: column; }
  .et-head { display: flex; align-items: baseline; gap: 0.6rem; padding-bottom: 0.8rem; border-bottom: 1px solid var(--hairline); margin-bottom: 0.9rem; }
  .et-verdict { font-family: var(--serif); font-size: 1.05rem; line-height: 1.4; color: var(--ink); margin-bottom: 1rem; font-variation-settings: "opsz" 32; }
  .et-verdict strong { font-weight: 600; }
  .et-label { font-family: var(--mono); font-size: 0.62rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; margin: 0.4rem 0 0.5rem; }
  .et-label.adv { color: #1f7a4d; }
  .et-label.risk { color: #c0431a; }
  .et-list { list-style: none; margin: 0 0 0.4rem; padding: 0; display: flex; flex-direction: column; gap: 0.45rem; }
  .et-list li { font-family: var(--sans); font-size: 0.86rem; line-height: 1.45; color: var(--body); padding-left: 1.35rem; position: relative; }
  .et-list.adv li::before { content: "✓"; position: absolute; left: 0; color: #2f8a5b; font-weight: 700; }
  .et-list.risk li::before { content: "⚠"; position: absolute; left: 0; color: var(--orange); font-size: 0.82rem; }
  .et-foot { margin-top: 1.15rem; font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.05em; color: var(--muted); line-height: 1.5; }
  .et-foot a { color: var(--periwinkle-deep); }
  @media (max-width: 800px) { .et-grid { grid-template-columns: 1fr; } }

  /* Recommendation taste — tier call + justification (gold), before the gate */
  .rec-taste { margin-bottom: 4rem; }
  .rt-eyebrow { font-family: var(--mono); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--periwinkle-deep); margin-bottom: 1rem; }
  .rt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: stretch; }
  .rt-card { border: 1px solid var(--tan); border-left: 4px solid #c79a3a; background: var(--canvas); padding: 1.4rem 1.5rem; display: flex; flex-direction: column; }
  .rt-head { display: flex; align-items: baseline; gap: 0.6rem; padding-bottom: 0.8rem; border-bottom: 1px solid var(--hairline); margin-bottom: 0.9rem; }
  .rt-tier { font-family: var(--serif); font-size: 1.15rem; line-height: 1.3; color: var(--ink); margin-bottom: 0.7rem; font-variation-settings: "opsz" 36; }
  .rt-tier strong { font-weight: 600; color: #9a7320; }
  .rt-why { font-family: var(--sans); font-size: 0.88rem; line-height: 1.5; color: var(--body); margin: 0; }
