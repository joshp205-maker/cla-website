---
// Live Leaflet OSM map. Centered on Davie FL (placeholder). 5-mile radius + subject + comp pins.
interface Props {
  id?: string;
  center?: [number, number];
  zoom?: number;
}
const {
  id = 'cla-trade-map',
  center = [26.0628, -80.2528],
  zoom = 11
} = Astro.props;
---
<div id={id} class="trade-map" data-center={center.join(',')} data-zoom={zoom}></div>

<style>
  .trade-map { position: absolute; inset: 0; }
  .trade-map :global(.leaflet-container) {
    background: #d8d3c8;
    font-family: var(--sans);
  }
  .trade-map :global(.you-pin) {
    width: 16px; height: 16px; border-radius: 50%;
    background: var(--periwinkle); border: 3px solid var(--ink);
    box-shadow: 0 0 0 2px rgba(125,143,184,0.35), 0 2px 4px rgba(0,0,0,0.35);
  }
  .trade-map :global(.comp-pin) {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--cocoa); border: 2px solid #fefdfa;
    box-shadow: 0 1px 2px rgba(0,0,0,0.4);
  }
</style>

<script>
  import L from 'leaflet';

  function initMap(el: HTMLElement) {
    const [lat, lng] = (el.dataset.center || '26.0628,-80.2528').split(',').map(Number);
    const zoom = Number(el.dataset.zoom || 11);
    const center: [number, number] = [lat, lng];

    const map = L.map(el, {
      zoomControl: false,
      attributionControl: false,
      scrollWheelZoom: false,
      dragging: false,
      doubleClickZoom: false,
      touchZoom: false,
      boxZoom: false,
      keyboard: false,
    }).setView(center, zoom);

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(map);

    L.circle(center, {
      radius: 8047,
      color: '#0a0a0a',
      weight: 1.2,
      opacity: 0.55,
      fillColor: '#7d8fb8',
      fillOpacity: 0.08,
      dashArray: '5,3',
    }).addTo(map);

    const youIcon = L.divIcon({
      className: '',
      html: '<div class="you-pin"></div>',
      iconSize: [22, 22],
      iconAnchor: [11, 11],
    });
    L.marker(center, { icon: youIcon }).addTo(map);

    const compIcon = L.divIcon({
      className: '',
      html: '<div class="comp-pin"></div>',
      iconSize: [14, 14],
      iconAnchor: [7, 7],
    });

    const comps: [number, number][] = [
      [26.0934, -80.2434], [26.0445, -80.2778], [26.0312, -80.1989], [26.0828, -80.3056],
      [26.0078, -80.2456], [26.0712, -80.2123], [26.0578, -80.3201], [26.0245, -80.2334],
      [26.0890, -80.1845], [26.0123, -80.3034],
    ];
    comps.forEach(c => L.marker(c, { icon: compIcon }).addTo(map));

    setTimeout(() => map.invalidateSize(), 200);
  }

  document.querySelectorAll<HTMLElement>('.trade-map').forEach(initMap);
</script>
