---
const links = [
  { label: 'Programs', href: '/programs' },
  { label: 'Method', href: '/method' },
  { label: 'Sample', href: '/sample' },
  { label: 'Insights', href: '/insights' },
  { label: 'About', href: '/about' },
];
---
<nav class="top">
  <div class="container">
    <a href="/" class="brand">
      <span>Competitive Landscape Analysis</span>
    </a>
    <div class="menu">
      {links.map(l => <a href={l.href}>{l.label}</a>)}
    </div>
    <div class="actions">
      <a href="/consult" class="pill">Schedule Consult</a>
    </div>
  </div>
</nav>

<style>
  nav.top {
    position: sticky; top: 0; z-index: 50;
    height: 72px; background: var(--canvas); backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--hairline);
    display: flex; align-items: center; padding: 0 2rem;
  }
  .container { max-width: var(--max); margin: 0 auto; width: 100%; display: flex; align-items: center; gap: 3rem; }
  .brand {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: var(--serif); font-weight: 500; font-size: 1.05rem; letter-spacing: -0.005em; color: var(--ink);
  }
  .brand-mark {
    width: 30px; height: 30px;
    color: var(--ink);
    display: flex; align-items: center; justify-content: center;
  }
  .menu {
    display: flex; gap: 2rem;
    font-size: 0.82rem; font-weight: 400; letter-spacing: 0.02em; color: var(--ink);
  }
  .menu a { position: relative; padding: 0.5rem 0; }
  .menu a::after {
    content: ""; position: absolute; bottom: 0; left: 0; right: 100%; height: 1px;
    background: var(--periwinkle); transition: right 0.3s ease;
  }
  .menu a:hover::after { right: 0; }
  .actions { margin-left: auto; display: flex; align-items: center; gap: 1.5rem; }
  .pill {
    padding: 0.65rem 1.1rem;
    background: var(--periwinkle); color: #fff;
    font-size: 0.74rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    transition: background 0.2s;
  }
  .pill:hover { background: var(--periwinkle-deep); }
</style>
