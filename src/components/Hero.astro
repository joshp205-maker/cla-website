---
// Hero — headline, eyebrow rule, lead, CTAs, HUD live readout, money card
---
<section class="hero">
  <div class="container">
    <div>
      <div class="meta-row reveal d1" style="margin-bottom: 2rem; padding-bottom: 0.8rem; border-bottom: 1px solid var(--hairline);">
        <span>cl-analysis.com</span>
        <span class="dot">·</span>
        <span>Vol. 01 · 2026</span>
        <span class="dot">·</span>
        <span>Built by operators</span>
        <span class="dot">·</span>
        <span class="pulse-tag">Item-level depth</span>
      </div>

      <div class="eyebrow reveal d1">
        Every Menu<span class="sep">·</span>Every Market<span class="sep">·</span>Every Time
      </div>

      <h1 class="reveal d2">
        Price with precision.<br />
        <span class="italic">No assumptions. No guesswork.</span>
      </h1>

      <p class="lead reveal d3">
        A complete view of your competitive set — every comp, every item, every price.
        Know where you stand, what the market will allow, and where to place yourself.
        <strong>No more guessing. No more hours wasted pulling data.</strong>
      </p>

      <div class="ctas reveal d4">
        <a href="/consult" class="btn-primary">
          Schedule Free 20-Min Consult<span class="arrow">→</span>
        </a>
        <a href="/sample" class="link-uc">
          See a real CLA<span class="arrow">›</span>
        </a>
      </div>
    </div>

    <div class="hud reveal d3">
      <div class="hud-head">
        <span>Brand-X · Davie FL</span>
        <span class="live">Live Readout</span>
      </div>
      <div class="hud-row"><span>Comps audited</span><span class="val">47</span></div>
      <div class="hud-row"><span>Menu items priced</span><span class="val">312</span></div>
      <div class="hud-row"><span>Tier position</span><span class="val">Tier 2 / 4</span></div>
      <div class="hud-row"><span>Underpriced vs. market</span><span class="val flag">7 items</span></div>
      <div class="hud-row"><span>Catering per-person Δ</span><span class="val up">−12.4%</span></div>
      <div class="hud-row"><span>Next snapshot</span><span class="val">2026.09</span></div>

      <div class="money">
        <span class="tag">EST. ANNUAL UPLIFT</span>
        <div class="label">If repriced to market</div>
        <div class="big">+ $38,400 / unit</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 5rem 2rem 6rem;
    background: var(--canvas);
    position: relative; overflow: hidden;
  }
  .hero::after {
    content: ""; position: absolute; right: -10%; top: -10%; width: 60%; height: 120%;
    background: radial-gradient(ellipse at center, rgba(125,143,184,0.06), transparent 60%);
    pointer-events: none;
  }
  .container {
    max-width: var(--max); margin: 0 auto;
    display: grid; grid-template-columns: 1.35fr 1fr; gap: 5rem; align-items: center;
    position: relative; z-index: 2;
  }
  .pulse-tag {
    display: inline-flex; align-items: center; gap: 0.4rem; color: var(--orange);
  }
  .pulse-tag::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--orange);
    animation: pulse 2s ease-in-out infinite;
  }
  .eyebrow {
    font-family: var(--mono); font-size: 0.78rem; font-weight: 500; letter-spacing: 0.24em;
    color: var(--ink); margin-bottom: 1.75rem; padding: 0.5rem 0;
    border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink);
    display: inline-block;
  }
  .eyebrow .sep { color: var(--tan); margin: 0 0.5rem; font-weight: 700; }
  h1 {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(2.6rem, 5.5vw, 4.6rem); line-height: 0.98; letter-spacing: -0.03em;
    color: var(--ink); margin: 0 0 0.2rem;
    font-variation-settings: "opsz" 96;
    max-width: 13em;
  }
  h1 .italic {
    font-style: italic; color: var(--periwinkle-deep); font-weight: 400;
    font-variation-settings: "opsz" 96;
  }
  .lead {
    font-family: var(--serif); font-weight: 300;
    font-size: 1.12rem; line-height: 1.6; color: var(--body);
    margin: 1.75rem 0 2.5rem; max-width: 36em;
    font-variation-settings: "opsz" 20;
  }
  .lead strong { font-weight: 500; color: var(--ink); }
  .ctas { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }

  /* HUD */
  .hud {
    background: var(--canvas-warm);
    border: 1px solid var(--tan);
    padding: 1.75rem;
    position: relative;
  }
  .hud::before {
    content: ""; position: absolute; top: -5px; left: -5px; width: 30px; height: 30px;
    border-top: 2px solid var(--ink); border-left: 2px solid var(--ink);
  }
  .hud::after {
    content: ""; position: absolute; bottom: -5px; right: -5px; width: 30px; height: 30px;
    border-bottom: 2px solid var(--ink); border-right: 2px solid var(--ink);
  }
  .hud-head {
    display: flex; justify-content: space-between; align-items: center;
    padding-bottom: 1rem; margin-bottom: 1rem;
    border-bottom: 1px solid var(--ink);
    font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink);
  }
  .hud-head .live { color: var(--periwinkle-deep); }
  .hud-head .live::before {
    content: ""; display: inline-block; width: 6px; height: 6px; border-radius: 50%;
    background: var(--orange); margin-right: 0.4rem; vertical-align: 1px;
    animation: pulse 2s ease-in-out infinite;
  }
  .hud-row {
    display: grid; grid-template-columns: 1fr auto;
    padding: 0.7rem 0;
    border-bottom: 1px dotted var(--hairline);
    font-family: var(--serif); font-size: 0.92rem; color: var(--body); font-weight: 300;
    align-items: baseline;
  }
  .hud-row:last-of-type { border-bottom: none; }
  .hud-row .val {
    font-family: var(--mono); font-size: 0.82rem; font-weight: 600; color: var(--ink);
  }
  .hud-row .val.flag { color: var(--periwinkle-deep); }
  .hud-row .val.up { color: var(--cocoa); }
  .money {
    margin-top: 1.25rem; padding: 1rem 1.25rem;
    background: var(--canvas);
    border: 1px solid var(--orange); border-left: 4px solid var(--orange);
    position: relative;
  }
  .money .tag {
    position: absolute; top: -10px; left: 1rem;
    background: var(--orange); color: #fff;
    padding: 3px 10px;
    font-family: var(--mono); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.15em;
  }
  .money .label {
    font-family: var(--mono); font-size: 0.66rem; font-weight: 500; letter-spacing: 0.15em;
    color: var(--cocoa); margin-top: 0.25rem;
  }
  .money .big {
    font-family: var(--serif); font-style: italic; font-weight: 400;
    font-size: 1.7rem; line-height: 1; color: var(--orange);
    margin-top: 0.35rem;
    font-variation-settings: "opsz" 36;
  }
</style>
